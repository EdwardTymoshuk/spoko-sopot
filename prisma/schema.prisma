generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Online ordering menu ────────────────────────────────────────────────────

model MenuItem {
  id            String   @id @default(uuid())
  name          String
  price         Int
  description   String?
  image         String?
  category      String
  isRecommended Boolean  @default(false)
  isActive      Boolean  @default(true)
  isOrderable   Boolean  @default(false)
  isOnMainPage  Boolean  @default(false)
  isArchived    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Settings {
  id                   String  @id @default(uuid())
  isOrderingOpen       Boolean @default(true)
  orderWaitTime        Int     @default(30)
  deliveryCost         Int     @default(0)
  deliveryZones        Json    @default("[]")
  menuDocuments        Json    @default("[]")
  pizzaCategoryEnabled Boolean @default(true)
  pizzaAvailability    Json    @default("[]")
}

// ─── Reservation domain ───────────────────────────────────────────────────────

model Reservation {
  id            String            @id @default(uuid())
  status        ReservationStatus @default(SENT)
  eventDate     DateTime
  startTime     String?
  endTime       String?
  adultsCount   Int
  childrenCount Int?
  eventType     EventType
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  offerSnapshot ReservationOfferSnapshot?
  extras        ReservationExtra[]
  contact       ReservationContact?
  summaryPdf   ReservationSummaryPdf?
}

model ReservationOfferSnapshot {
  id                String      @id @default(uuid())
  reservationId     String      @unique
  packageCode       PackageCode
  servingType       String
  basePricePerAdult Int
  durationHours     Int
  subtotal          Int
  serviceFee        Int
  total             Int
  createdAt         DateTime    @default(now())

  reservation Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
}

model ReservationExtra {
  id            String               @id @default(uuid())
  reservationId String
  type          ReservationExtraType
  label         String
  quantity      Int
  unitPrice     Int
  totalPrice    Int
  metadata      Json?

  reservation Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
}

model ReservationContact {
  id            String   @id @default(uuid())
  reservationId String   @unique
  name          String
  phone         String
  email         String
  notes         String?
  createdAt     DateTime @default(now())

  reservation Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
}

model ReservationSummaryPdf {
  id            String      @id @default(uuid())
  reservationId String      @unique
  filename      String
  mimeType      String      @default("application/pdf")
  content       Bytes
  createdAt     DateTime    @default(now())

  reservation Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
}

model CalendarAvailability {
  id            String   @id @default(uuid())
  date          DateTime @unique
  isBlocked     Boolean  @default(false)
  basePriceFrom Int?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum ReservationStatus {
  DRAFT
  SENT
  CONFIRMED
  CANCELLED
}

enum EventType {
  BIRTHDAY
  ANNIVERSARY
  COMMUNION
  CHRISTENING
  COMPANY_EVENT
  WEDDING
  OTHER
}

enum PackageCode {
  SILVER
  GOLD
  PLATINUM
}

enum ReservationExtraType {
  EXTENDED_TIME
  COLD_PLATE
  PREMIUM_PLATTER
  KIDS_MENU
  DESSERTS
  CAKE
  SPECIAL_DIET
}
